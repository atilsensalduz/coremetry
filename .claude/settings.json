{
  "permissions": {
    "allow": [
      "Bash(go build *)",
      "Bash(go vet ./...)",
      "Bash(go vet *)",
      "Bash(go list *)",
      "Bash(make docker-up)",
      "Bash(npx tsc --noEmit)",
      "Bash(npx tsc --noEmit *)",
      "Bash(gh run watch *)",
      "Bash(helm template *)",
      "Bash(helm lint *)",
      "Bash(helm show *)",
      "Bash(helm pull *)",
      "Bash(docker compose ps *)",
      "Bash(docker compose logs *)",
      "Bash(docker compose config *)",
      "Bash(go test *)",
      "Bash(make test)",
      "Bash(make test-race)",
      "Bash(make audit)",
      "Bash(kubectl get *)",
      "Bash(kubectl describe *)",
      "Bash(kubectl logs *)",
      "Bash(kubectl rollout status *)",
      "Bash(kubectl top *)",
      "Bash(minikube status)",
      "Bash(minikube status *)",
      "Bash(minikube dashboard *)",
      "Bash(minikube config get *)",
      "Bash(docker images *)",
      "Bash(docker inspect *)",
      "Bash(docker ps *)"
    ]
  },
"hooks": {
  "PostToolUse": [
    {
      "matcher": "Edit|Write|MultiEdit",
      "hooks": [
        { "type": "command", "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/post-edit-check.sh\"" }
      ]
    }
  ]
},
  "enabledPlugins": {
    "superpowers@claude-plugins-official": true
  }
}
