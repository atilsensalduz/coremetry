*.swp
*~
.DS_Store

# Local env / secrets
.env
.env.*
!.env.example

# Logs + tmp
*.log
tmp/
# Anchored to repo root — bare `logs/` would match
# frontend/src/app/logs/ (the Logs explorer route).
/logs/

# Helm
charts/*.tgz
charts/*/charts/

# Local data dirs that some compose runs leave behind
data/
clickhouse-data/
grafana-data/
frontend/dist/bundle-analysis.html
VERSION.txt

# Claude Code — shared settings + skills land in the repo, but
# per-developer overrides (.claude/settings.local.json) stay
# private.
.claude/settings.local.json
.claude/worktrees/

# Local agent tooling (machine-managed skill installs + lockfile)
.agents/
skills-lock.json

# Playwright MCP browser profile / verification output
.playwright-mcp/

# Stray root npm cache (real one lives in frontend/)
/node_modules/

# Verification screenshots land at the repo root during
# Playwright runs — never commit them. Tracked logo assets
# stay tracked regardless (gitignore only hides untracked).
/*.png
!/OpenTelemetry.png

# Design handoff working dirs (prototypes must NOT enter
# frontend/src — vite breaks on stray ./App→app.jsx imports)
design_handoff_*/
